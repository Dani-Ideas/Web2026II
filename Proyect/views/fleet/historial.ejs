<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body class="layout">
  <%- include('../partials/sidebar', { currentPage: 'fleet' }) %>
  <main class="main">
    <%- include('../partials/topbar') %>
    <div class="content">

      <%
        const IMG_MAP = {
          'camión':      '/images/Trailer.png',
          'furgoneta':   '/images/camioneta.png',
          'automóvil':   '/images/Carro.png',
          'motocicleta': '/images/Moto.png',
        };
        const STATUS_LABEL = { pass: 'Aprobado', caution: 'Precaución', fail: 'Fallido' };
        const MAINT_STATUS = { pendiente: 'Pendiente', en_progreso: 'En Progreso', completado: 'Completado' };
        const MAINT_TYPE   = { preventivo: 'Preventivo', correctivo: 'Correctivo', predictivo: 'Predictivo' };

        function pagerUrl(pageInspVal, pageMaintVal) {
          return `/flota/${vehicle.id}/historial?pageInsp=${pageInspVal}&pageMaint=${pageMaintVal}`;
        }
      %>

      <!-- ── Vehicle header ──────────────────────────────────── -->
      <div class="hist-header">
        <div class="hist-header__img-wrap">
          <% if (IMG_MAP[vehicle.type]) { %>
            <img src="<%= IMG_MAP[vehicle.type] %>" alt="<%= vehicle.type %>" class="hist-header__img" />
          <% } %>
        </div>
        <div class="hist-header__info">
          <span class="insp-ph__sup"><%= vehicle.type %></span>
          <h1 class="insp-ph__title"><%= vehicle.brand %> <%= vehicle.model %></h1>
          <p class="hist-header__meta">
            <span class="badge badge--<%= vehicle.status %>"><%= vehicle.status %></span>
            <span class="hist-header__plate"><%= vehicle.plate %></span>
            <% if (vehicle.year) { %><span>· <%= vehicle.year %></span><% } %>
          </p>
        </div>
        <div class="hist-header__counts">
          <div class="hist-count-box">
            <span class="hist-count-box__num"><%= totalInsp %></span>
            <span class="hist-count-box__lbl">Inspecciones</span>
          </div>
          <div class="hist-count-box">
            <span class="hist-count-box__num"><%= totalMaint %></span>
            <span class="hist-count-box__lbl">Mantenimientos</span>
          </div>
        </div>
      </div>

      <div class="hist-grid">

        <!-- ── Inspections column ────────────────────────────── -->
        <section class="hist-col">
          <div class="hist-col__head">
            <h2 class="hist-col__title">Inspecciones</h2>
            <span class="hist-col__total"><%= totalInsp %> registro<%= totalInsp !== 1 ? 's' : '' %></span>
          </div>

          <% if (inspections.length === 0) { %>
            <div class="hist-empty">Sin inspecciones registradas</div>
          <% } else { %>
            <% inspections.forEach(insp => { %>
              <div class="hist-card hist-card--insp">
                <div class="hist-card__top">
                  <span class="badge badge--<%= insp.result %>">
                    <%= insp.result === 'pass' ? '✓ Aprobado' : '✗ Fallido' %>
                  </span>
                  <span class="hist-card__date table__mono">
                    <%= new Date(insp.created_at).toLocaleString('es-ES', {
                      day:'2-digit', month:'short', year:'numeric',
                      hour:'2-digit', minute:'2-digit'
                    }) %>
                  </span>
                </div>

                <p class="hist-card__driver">&#128100; <%= insp.driver_name %></p>

                <!-- Mini star ratings for each category -->
                <div class="hist-card__ratings">
                  <% [
                    ['Motor',      insp.engine_rating, insp.engine],
                    ['Luces',      insp.lights_rating, insp.lights],
                    ['Neumáticos', insp.tires_rating,  insp.tires],
                    ['Seguridad',  insp.safety_rating, insp.safety],
                  ].forEach(([lbl, rating, status]) => { %>
                    <div class="hist-rating-row">
                      <span class="hist-rating-lbl"><%= lbl %></span>
                      <span class="hist-mini-stars">
                        <% for (let s = 1; s <= 5; s++) { %>
                          <span class="hist-star <%= s <= (rating||0) ? 'hist-star--on' : '' %>">&#9733;</span>
                        <% } %>
                      </span>
                      <span class="badge badge--<%= status %> hist-badge-sm">
                        <%= STATUS_LABEL[status] || status %>
                      </span>
                    </div>
                  <% }) %>
                </div>

                <% if (insp.photos) { %>
                  <div class="hist-card__photos">
                    <% insp.photos.split(',').slice(0,3).forEach(ph => { %>
                      <img src="/uploads/<%= ph %>" alt="foto" class="hist-thumb" />
                    <% }) %>
                    <% if (insp.photos.split(',').length > 3) { %>
                      <span class="hist-thumb-more">+<%= insp.photos.split(',').length - 3 %></span>
                    <% } %>
                  </div>
                <% } %>

                <% if (insp.notes) { %>
                  <p class="hist-card__notes"><%= insp.notes.length > 120 ? insp.notes.slice(0,120)+'…' : insp.notes %></p>
                <% } %>

                <div class="hist-card__foot">
                  <a href="/inspecciones/<%= insp.id %>" class="btn btn--ghost btn--sm">Ver reporte completo &#8594;</a>
                </div>
              </div>
            <% }) %>

            <!-- Pagination inspections -->
            <% if (pagesInsp > 1) { %>
              <div class="hist-pager">
                <% if (pageInsp > 1) { %>
                  <a href="<%= pagerUrl(pageInsp - 1, pageMaint) %>" class="btn btn--ghost btn--sm">&#8592; Anterior</a>
                <% } else { %>
                  <span class="btn btn--ghost btn--sm hist-pager__disabled">&#8592; Anterior</span>
                <% } %>
                <span class="hist-pager__info"><%= pageInsp %> / <%= pagesInsp %></span>
                <% if (pageInsp < pagesInsp) { %>
                  <a href="<%= pagerUrl(pageInsp + 1, pageMaint) %>" class="btn btn--ghost btn--sm">Siguiente &#8594;</a>
                <% } else { %>
                  <span class="btn btn--ghost btn--sm hist-pager__disabled">Siguiente &#8594;</span>
                <% } %>
              </div>
            <% } %>
          <% } %>
        </section>

        <!-- ── Maintenance column ────────────────────────────── -->
        <section class="hist-col">
          <div class="hist-col__head">
            <h2 class="hist-col__title">Mantenimientos</h2>
            <span class="hist-col__total"><%= totalMaint %> registro<%= totalMaint !== 1 ? 's' : '' %></span>
          </div>

          <% if (maintenances.length === 0) { %>
            <div class="hist-empty">Sin registros de mantenimiento</div>
          <% } else { %>
            <% maintenances.forEach(m => { %>
              <div class="hist-card hist-card--maint">
                <div class="hist-card__top">
                  <span class="badge badge--<%= m.status %>">
                    <%= MAINT_STATUS[m.status] || m.status %>
                  </span>
                  <span class="badge badge--<%= m.type === 'preventivo' ? 'pass' : m.type === 'correctivo' ? 'fail' : 'caution' %>">
                    <%= MAINT_TYPE[m.type] || m.type %>
                  </span>
                  <span class="hist-card__date table__mono" style="margin-left:auto">
                    <%= new Date(m.created_at).toLocaleDateString('es-ES', {day:'2-digit',month:'short',year:'numeric'}) %>
                  </span>
                </div>

                <p class="hist-card__desc"><%= m.description %></p>

                <div class="hist-maint-meta">
                  <% if (m.scheduled_date) { %>
                    <div class="hist-meta-item">
                      <span class="hist-meta-item__lbl">Programado</span>
                      <span class="hist-meta-item__val table__mono">
                        <%= new Date(m.scheduled_date).toLocaleDateString('es-ES') %>
                      </span>
                    </div>
                  <% } %>
                  <% if (m.completed_date) { %>
                    <div class="hist-meta-item">
                      <span class="hist-meta-item__lbl">Completado</span>
                      <span class="hist-meta-item__val table__mono">
                        <%= new Date(m.completed_date).toLocaleDateString('es-ES') %>
                      </span>
                    </div>
                  <% } %>
                  <% if (m.cost > 0) { %>
                    <div class="hist-meta-item">
                      <span class="hist-meta-item__lbl">Costo</span>
                      <span class="hist-meta-item__val table__mono">
                        $<%= parseFloat(m.cost).toLocaleString('es-ES', {minimumFractionDigits:2}) %>
                      </span>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }) %>

            <!-- Pagination maintenances -->
            <% if (pagesMaint > 1) { %>
              <div class="hist-pager">
                <% if (pageMaint > 1) { %>
                  <a href="<%= pagerUrl(pageInsp, pageMaint - 1) %>" class="btn btn--ghost btn--sm">&#8592; Anterior</a>
                <% } else { %>
                  <span class="btn btn--ghost btn--sm hist-pager__disabled">&#8592; Anterior</span>
                <% } %>
                <span class="hist-pager__info"><%= pageMaint %> / <%= pagesMaint %></span>
                <% if (pageMaint < pagesMaint) { %>
                  <a href="<%= pagerUrl(pageInsp, pageMaint + 1) %>" class="btn btn--ghost btn--sm">Siguiente &#8594;</a>
                <% } else { %>
                  <span class="btn btn--ghost btn--sm hist-pager__disabled">Siguiente &#8594;</span>
                <% } %>
              </div>
            <% } %>
          <% } %>
        </section>

      </div><!-- /hist-grid -->

      <div class="form__actions">
        <a href="/flota" class="btn btn--ghost">&#8592; Volver a Flota</a>
        <a href="/inspecciones/nueva" class="btn btn--action">+ Nueva Inspección</a>
      </div>

    </div><!-- /content -->
  </main>
</body>
</html>
