<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body class="layout">
  <%- include('../partials/sidebar', { currentPage: 'inspections' }) %>
  <main class="main">

    <div class="content insp-page">
      <form method="POST" action="/inspecciones" enctype="multipart/form-data" id="inspForm">

        <!-- ── Page header ─────────────────────────────────────── -->
        <div class="insp-ph">
          <div class="insp-ph__left">
            <span class="insp-ph__sup">Inspección Operativa</span>
            <h1 class="insp-ph__title">Formulario de Inspección Diaria</h1>
            <p class="insp-ph__vehicle">
              Vehículo: <span id="headerVehicle" class="insp-ph__vehicle-name">—</span>
            </p>
          </div>
          <div class="insp-ph__right">
            <span class="insp-ph__date-label">FECHA Y HORA</span>
            <span class="insp-ph__date-val" id="liveDate"></span>
          </div>
        </div>

        <!-- ── Driver + vehicle selectors ─────────────────────── -->
        <div class="insp-selectors">
          <div class="form__group">
            <label class="form__label">Vehículo</label>
            <select name="vehicle_id" id="vehicleSelect" class="input input--select" required
                    onchange="onVehicleChange(this)">
              <option value="">Seleccionar vehículo…</option>
              <% vehicles.forEach(v => { %>
                <option value="<%= v.id %>" data-type="<%= v.type %>"
                        data-label="<%= v.brand %> <%= v.model %> [<%= v.plate %>]">
                  <%= v.plate %> — <%= v.brand %> <%= v.model %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="form__group">
            <label class="form__label">Conductor</label>
            <input type="text" name="driver_name" class="input" required
                   placeholder="Nombre completo del conductor" />
          </div>
        </div>

        <!-- ── Route selector ─────────────────────────────────── -->
        <div class="db-route-pick">
          <div class="db-route-pick__head">
            <label class="form__label">Ruta Asignada</label>
            <span class="db-route-pick__demo">
              &#8505; Demo — no se pueden agregar rutas adicionales
            </span>
          </div>
          <div class="db-route-pick__options">
            <% [
              { val:'A', name:'Ruta A', desc:'Terminal Norte → Destino A', color:'var(--orange)' },
              { val:'B', name:'Ruta B', desc:'Terminal Sur → Destino B',   color:'#8192a7' },
              { val:'C', name:'Ruta C', desc:'Terminal Este → Destino C',  color:'var(--pass-text)' },
            ].forEach(r => { %>
              <label class="db-route-opt">
                <input type="radio" name="route" value="<%= r.val %>" class="db-route-opt__radio" required />
                <div class="db-route-opt__card">
                  <span class="db-route-opt__badge" style="background:<%= r.color %>"><%= r.val %></span>
                  <div>
                    <p class="db-route-opt__name"><%= r.name %></p>
                    <p class="db-route-opt__desc"><%= r.desc %></p>
                  </div>
                </div>
              </label>
            <% }) %>
          </div>
        </div>

        <!-- ── 12-col main grid ────────────────────────────────── -->
        <div class="insp-grid">

          <!-- LEFT 8/12 — Category carousel ──────────────────── -->
          <div class="insp-left">

            <!-- Dot progress -->
            <div class="car-dots">
              <% ['Motor y Mecánica','Iluminación','Neumáticos','Seguridad'].forEach((lbl,i) => { %>
                <button type="button"
                  class="car-dot <%= i===0 ? 'car-dot--active' : '' %>"
                  onclick="goToSlide(<%= i %>)"
                  title="<%= lbl %>"></button>
              <% }) %>
            </div>

            <!-- Carousel -->
            <div class="car-wrap">
              <div class="car-track" id="carTrack">

                <!-- Slide 1 — Motor ───────────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#041627,#1a3a5c)">
                    <span class="car-slide__icon">&#9881;</span>
                    <div>
                      <div class="car-slide__cat">Categoría 1 / 4</div>
                      <div class="car-slide__name">Motor y Mecánica</div>
                    </div>
                  </div>
                  <div class="car-slide__body">
                    <% [
                      'Nivel de Aceite (Varilla/Sensor)',
                      'Líquido Refrigerante / Anticongelante',
                      'Estado de Correas y Tensores',
                      'Fugas visibles de fluidos'
                    ].forEach(item => { %>
                      <label class="chk-row">
                        <span class="chk-label"><%= item %></span>
                        <input type="checkbox" name="engine_items[]" value="<%= item %>" class="chk-box" />
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-row">
                      <span class="star-row__label">Calificación general</span>
                      <div class="stars" id="starsEngine">
                        <% for(let s=1;s<=5;s++) { %>
                          <span class="star" data-val="<%= s %>"
                                onclick="rateStar('engine_rating',<%= s %>)">&#9733;</span>
                        <% } %>
                      </div>
                      <input type="hidden" name="engine_rating" id="engine_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()" disabled>&#8592; Anterior</button>
                      <button type="button" class="car-btn car-btn--next" id="next0" onclick="nextSlide()" disabled>Siguiente &#8594;</button>
                    </div>
                  </div>
                </div>

                <!-- Slide 2 — Luces ───────────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#1a2b3c,#2a4060)">
                    <span class="car-slide__icon">&#128161;</span>
                    <div>
                      <div class="car-slide__cat">Categoría 2 / 4</div>
                      <div class="car-slide__name">Sistema de Iluminación</div>
                    </div>
                  </div>
                  <div class="car-slide__body car-slide__body--2col">
                    <% [
                      'Luces de Cruce / Carretera',
                      'Intermitentes / Emergencia',
                      'Luces de Freno / Posición',
                      'Iluminación de Matrícula'
                    ].forEach(item => { %>
                      <label class="chk-row">
                        <span class="chk-label"><%= item %></span>
                        <input type="checkbox" name="lights_items[]" value="<%= item %>" class="chk-box" />
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-row">
                      <span class="star-row__label">Calificación general</span>
                      <div class="stars" id="starsLights">
                        <% for(let s=1;s<=5;s++) { %>
                          <span class="star" data-val="<%= s %>"
                                onclick="rateStar('lights_rating',<%= s %>)">&#9733;</span>
                        <% } %>
                      </div>
                      <input type="hidden" name="lights_rating" id="lights_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()">&#8592; Anterior</button>
                      <button type="button" class="car-btn car-btn--next" id="next1" onclick="nextSlide()" disabled>Siguiente &#8594;</button>
                    </div>
                  </div>
                </div>

                <!-- Slide 3 — Neumáticos ──────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#0d2438,#1a3a5c)">
                    <span class="car-slide__icon">&#9898;</span>
                    <div>
                      <div class="car-slide__cat">Categoría 3 / 4</div>
                      <div class="car-slide__name">Ruedas y Neumáticos</div>
                    </div>
                  </div>
                  <div class="car-slide__body">
                    <% [
                      'Presión de Aire (Visual / Medida)',
                      'Profundidad del Dibujo (Mín 1.6 mm)',
                      'Desgaste Irregular / Daños Visibles',
                      'Tuercas y Espárragos de Rueda'
                    ].forEach(item => { %>
                      <label class="chk-row">
                        <span class="chk-label"><%= item %></span>
                        <input type="checkbox" name="tires_items[]" value="<%= item %>" class="chk-box" />
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-row">
                      <span class="star-row__label">Calificación general</span>
                      <div class="stars" id="starsTires">
                        <% for(let s=1;s<=5;s++) { %>
                          <span class="star" data-val="<%= s %>"
                                onclick="rateStar('tires_rating',<%= s %>)">&#9733;</span>
                        <% } %>
                      </div>
                      <input type="hidden" name="tires_rating" id="tires_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()">&#8592; Anterior</button>
                      <button type="button" class="car-btn car-btn--next" id="next2" onclick="nextSlide()" disabled>Siguiente &#8594;</button>
                    </div>
                  </div>
                </div>

                <!-- Slide 4 — Seguridad ───────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#041627,#7c3a00)">
                    <span class="car-slide__icon">&#128737;</span>
                    <div>
                      <div class="car-slide__cat">Categoría 4 / 4</div>
                      <div class="car-slide__name">Elementos de Seguridad</div>
                    </div>
                  </div>
                  <div class="car-slide__body">
                    <% [
                      'Frenos de Servicio y Estacionamiento',
                      'Extintor (Carga y Fecha Vigente)',
                      'Chalecos y Triángulos de Señalización',
                      'Cinturones de Seguridad'
                    ].forEach(item => { %>
                      <label class="chk-row">
                        <span class="chk-label"><%= item %></span>
                        <input type="checkbox" name="safety_items[]" value="<%= item %>" class="chk-box" />
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-row">
                      <span class="star-row__label">Calificación general</span>
                      <div class="stars" id="starsSafety">
                        <% for(let s=1;s<=5;s++) { %>
                          <span class="star" data-val="<%= s %>"
                                onclick="rateStar('safety_rating',<%= s %>)">&#9733;</span>
                        <% } %>
                      </div>
                      <input type="hidden" name="safety_rating" id="safety_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()">&#8592; Anterior</button>
                      <span class="car-hint">Completa la columna derecha y envía</span>
                    </div>
                  </div>
                </div>

              </div><!-- /car-track -->
            </div><!-- /car-wrap -->
          </div><!-- /insp-left -->

          <!-- RIGHT 4/12 — Evidence panels ───────────────────── -->
          <div class="insp-right">

            <!-- Observations -->
            <section class="insp-card">
              <h3 class="insp-card__title">Observaciones</h3>
              <textarea name="notes" class="input input--textarea insp-obs"
                placeholder="Describa cualquier anomalía detectada…"></textarea>
            </section>

            <!-- Vehicle damage map -->
            <section class="insp-card">
              <h3 class="insp-card__title">Mapa de Daños</h3>
              <p class="insp-card__sub">Toca la imagen para marcar áreas afectadas</p>
              <div class="dmg-wrap" id="dmgWrap">
                <img id="vehicleImg" src="" alt="" class="dmg-img" />
                <canvas id="dmgCanvas" class="dmg-canvas"></canvas>
                <div class="dmg-placeholder" id="dmgPlaceholder">
                  Selecciona un vehículo para activar el mapa
                </div>
              </div>
              <div class="dmg-foot">
                <button type="button" class="btn btn--ghost btn--sm" onclick="clearDamage()">Limpiar marcas</button>
                <span class="dmg-count" id="dmgCount">0 marcas</span>
              </div>
              <input type="hidden" name="damage_map" id="damageMapData" />
            </section>

            <!-- Photo evidence -->
            <section class="insp-card">
              <h3 class="insp-card__title">Evidencia Fotográfica</h3>
              <label class="photo-drop" for="photoInput">
                <span class="photo-drop__icon">&#128247;</span>
                <p class="photo-drop__text">Tocar para subir fotos de desperfectos</p>
              </label>
              <input type="file" id="photoInput" name="evidencia" multiple accept="image/*"
                     class="photo-file-input" onchange="previewPhotos(this)" />
              <div class="photo-preview-grid" id="photoGrid"></div>
            </section>

            <!-- Digital signature -->
            <section class="insp-card">
              <h3 class="insp-card__title">Firma Digital del Conductor</h3>
              <div class="sig-box">
                <canvas id="signatureCanvas" class="signature-canvas"></canvas>
                <div class="sig-baseline"></div>
                <p class="sig-hint">Firme aquí</p>
              </div>
              <div class="sig-foot">
                <span class="sig-name" id="sigDriverName">—</span>
                <button type="button" class="btn btn--ghost btn--sm"
                        onclick="clearSignature()">Limpiar</button>
              </div>
              <input type="hidden" name="signature" id="signatureData" />
            </section>

            <!-- Submit -->
            <button type="submit" class="btn-submit-insp">
              <span class="btn-submit-insp__icon">&#10148;</span>
              FINALIZAR INSPECCIÓN
            </button>

          </div><!-- /insp-right -->
        </div><!-- /insp-grid -->
      </form>
    </div><!-- /content -->

    <!-- Success toast -->
    <div class="insp-toast" id="inspToast">
      <span class="insp-toast__icon">&#10003;</span>
      <div>
        <strong>Inspección Registrada</strong>
        <p id="toastMsg"></p>
      </div>
    </div>

  </main>

  <script>
  /* ── Live date ──────────────────────────────────────────────── */
  (function tick() {
    const el = document.getElementById('liveDate');
    if (el) el.textContent = new Date().toLocaleString('es-ES', {
      day:'2-digit', month:'short', year:'numeric',
      hour:'2-digit', minute:'2-digit'
    }).toUpperCase();
    setTimeout(tick, 30000);
  })();

  /* ── Carousel ───────────────────────────────────────────────── */
  let cur = 0;
  const TOTAL = 4;
  const track = document.getElementById('carTrack');
  const dots  = document.querySelectorAll('.car-dot');

  function goToSlide(n) {
    cur = Math.max(0, Math.min(TOTAL - 1, n));
    track.style.transform = `translateX(-${cur * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('car-dot--active', i === cur));
    document.querySelectorAll('.car-btn--prev').forEach(b => b.disabled = cur === 0);
  }
  function nextSlide() { goToSlide(cur + 1); }
  function prevSlide() { goToSlide(cur - 1); }

  /* ── Star rating ────────────────────────────────────────────── */
  const starContainers = {
    engine_rating: document.getElementById('starsEngine'),
    lights_rating: document.getElementById('starsLights'),
    tires_rating:  document.getElementById('starsTires'),
    safety_rating: document.getElementById('starsSafety'),
  };
  const nextIds = ['next0','next1','next2'];

  function rateStar(field, val) {
    document.getElementById(field).value = val;
    // Render filled stars
    starContainers[field].querySelectorAll('.star').forEach(s =>
      s.classList.toggle('star--on', parseInt(s.dataset.val) <= val)
    );
    // Enable next button
    const btn = document.getElementById('next' + cur);
    if (btn) btn.disabled = false;
    // Auto-advance after 650ms (not on last slide)
    if (cur < TOTAL - 1) setTimeout(() => goToSlide(cur + 1), 650);
  }

  // Hover preview
  document.querySelectorAll('.stars').forEach(group => {
    group.querySelectorAll('.star').forEach(star => {
      star.addEventListener('mouseenter', () => {
        const v = parseInt(star.dataset.val);
        group.querySelectorAll('.star').forEach(s =>
          s.classList.toggle('star--hover', parseInt(s.dataset.val) <= v));
      });
      star.addEventListener('mouseleave', () =>
        group.querySelectorAll('.star').forEach(s => s.classList.remove('star--hover')));
    });
  });

  /* ── Vehicle select → header + image ───────────────────────── */
  const IMAGE_MAP = {
    'camión':      '/images/Trailer.png',
    'furgoneta':   '/images/camioneta.png',
    'automóvil':   '/images/Carro.png',
    'motocicleta': '/images/Moto.png',
  };

  const dmgWrap   = document.getElementById('dmgWrap');
  const dmgCanvas = document.getElementById('dmgCanvas');
  const dmgCtx    = dmgCanvas.getContext('2d');
  const vImg      = document.getElementById('vehicleImg');
  const dmgPH     = document.getElementById('dmgPlaceholder');
  const dmgCount  = document.getElementById('dmgCount');
  const marks     = [];
  let   ready     = false;

  function activateCanvas() {
    dmgCanvas.width  = dmgWrap.clientWidth;
    dmgCanvas.height = dmgWrap.clientHeight;
    ready = true;
    marks.length = 0;
    dmgCtx.clearRect(0, 0, dmgCanvas.width, dmgCanvas.height);
    updateCount();
  }

  function onVehicleChange(sel) {
    const opt  = sel.options[sel.selectedIndex];
    const type = opt.dataset.type || '';
    const lbl  = opt.dataset.label || '—';
    const src  = IMAGE_MAP[type] || '';

    // Update header
    document.getElementById('headerVehicle').textContent = lbl;
    document.getElementById('sigDriverName').textContent = '—';

    if (!src) {
      dmgPH.style.display = 'flex';
      vImg.src = '';
      ready = false;
      return;
    }

    dmgPH.style.display = 'none';

    // Fix: set onload BEFORE src so cached images also trigger it
    vImg.onload = activateCanvas;
    vImg.src = src;

    // If already cached (complete + has natural dimensions) fire immediately
    if (vImg.complete && vImg.naturalWidth > 0) activateCanvas();
  }

  // Update driver name in signature area as user types
  const driverInput = document.querySelector('input[name="driver_name"]');
  if (driverInput) {
    driverInput.addEventListener('input', function() {
      document.getElementById('sigDriverName').textContent = this.value || '—';
    });
  }

  /* ── Damage canvas clicks ───────────────────────────────────── */
  dmgCanvas.addEventListener('click', e => {
    if (!ready) return;
    const r = dmgCanvas.getBoundingClientRect();
    marks.push({ x: e.clientX - r.left, y: e.clientY - r.top });
    redraw();
    saveMap();
  });
  dmgCanvas.addEventListener('touchend', e => {
    if (!ready) return;
    e.preventDefault();
    const t = e.changedTouches[0];
    const r = dmgCanvas.getBoundingClientRect();
    marks.push({ x: t.clientX - r.left, y: t.clientY - r.top });
    redraw();
    saveMap();
  });

  function redraw() {
    dmgCtx.clearRect(0, 0, dmgCanvas.width, dmgCanvas.height);
    marks.forEach(({ x, y }, i) => {
      dmgCtx.beginPath();
      dmgCtx.arc(x, y, 16, 0, Math.PI * 2);
      dmgCtx.strokeStyle = '#ba1a1a';
      dmgCtx.lineWidth = 2.5;
      dmgCtx.stroke();
      dmgCtx.fillStyle = 'rgba(186,26,26,0.12)';
      dmgCtx.fill();
      dmgCtx.fillStyle = '#ba1a1a';
      dmgCtx.font = 'bold 10px Inter,sans-serif';
      dmgCtx.textAlign = 'center';
      dmgCtx.textBaseline = 'middle';
      dmgCtx.fillText(i + 1, x, y);
    });
    updateCount();
  }

  function updateCount() {
    dmgCount.textContent = marks.length + (marks.length === 1 ? ' marca' : ' marcas');
  }

  function saveMap() {
    document.getElementById('damageMapData').value = dmgCanvas.toDataURL();
  }

  function clearDamage() {
    marks.length = 0;
    dmgCtx.clearRect(0, 0, dmgCanvas.width, dmgCanvas.height);
    document.getElementById('damageMapData').value = '';
    updateCount();
  }

  /* ── Signature canvas ───────────────────────────────────────── */
  const sigCv  = document.getElementById('signatureCanvas');
  const sigCtx = sigCv.getContext('2d');
  let   draw   = false;

  // Size canvas to its CSS box
  function resizeSig() {
    sigCv.width  = sigCv.offsetWidth;
    sigCv.height = sigCv.offsetHeight;
  }
  window.addEventListener('load', resizeSig);

  function sp(e) {
    const r = sigCv.getBoundingClientRect();
    return { x: (e.clientX ?? e.pageX) - r.left, y: (e.clientY ?? e.pageY) - r.top };
  }
  sigCv.addEventListener('mousedown',  e => { draw=true; sigCtx.beginPath(); const p=sp(e); sigCtx.moveTo(p.x,p.y); });
  sigCv.addEventListener('mousemove',  e => { if(!draw)return; const p=sp(e); sigCtx.lineTo(p.x,p.y); sigCtx.strokeStyle='#041627'; sigCtx.lineWidth=2; sigCtx.lineCap='round'; sigCtx.stroke(); });
  sigCv.addEventListener('mouseup',    () => { draw=false; saveSig(); });
  sigCv.addEventListener('mouseleave', () => { draw=false; });
  sigCv.addEventListener('touchstart', e => { e.preventDefault(); draw=true; const p=sp(e.touches[0]); sigCtx.beginPath(); sigCtx.moveTo(p.x,p.y); });
  sigCv.addEventListener('touchmove',  e => { e.preventDefault(); if(!draw)return; const p=sp(e.touches[0]); sigCtx.lineTo(p.x,p.y); sigCtx.strokeStyle='#041627'; sigCtx.lineWidth=2; sigCtx.lineCap='round'; sigCtx.stroke(); });
  sigCv.addEventListener('touchend',   () => { draw=false; saveSig(); });
  function saveSig()   { document.getElementById('signatureData').value = sigCv.toDataURL(); }
  function clearSignature() { sigCtx.clearRect(0,0,sigCv.width,sigCv.height); document.getElementById('signatureData').value=''; }

  /* ── Photo preview ──────────────────────────────────────────── */
  function previewPhotos(input) {
    const grid = document.getElementById('photoGrid');
    grid.innerHTML = '';
    Array.from(input.files).slice(0, 5).forEach(file => {
      const reader = new FileReader();
      reader.onload = e => {
        const d = document.createElement('div');
        d.className = 'photo-thumb';
        d.innerHTML = `<img src="${e.target.result}" alt="preview" />`;
        grid.appendChild(d);
      };
      reader.readAsDataURL(file);
    });
  }
  </script>
</body>
</html>
