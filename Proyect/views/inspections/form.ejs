<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body class="layout">
  <%- include('../partials/sidebar', { currentPage: 'inspections' }) %>
  <main class="main">
    <%- include('../partials/topbar') %>
    <div class="content">

      <form method="POST" action="/inspecciones" enctype="multipart/form-data" id="inspForm">

        <!-- ── Header ────────────────────────────────────────────── -->
        <div class="insp-header">
          <div class="insp-header__left">
            <span class="insp-header__sup">Inspección Operativa</span>
            <h1 class="insp-header__title">Formulario de Inspección Diaria</h1>
          </div>
          <div class="insp-header__fields">
            <div class="form__group">
              <label class="form__label">Vehículo</label>
              <select name="vehicle_id" id="vehicleSelect" class="input input--select" required onchange="onVehicleChange(this)">
                <option value="">Seleccionar...</option>
                <% vehicles.forEach(v => { %>
                  <option value="<%= v.id %>" data-type="<%= v.type %>">
                    <%= v.plate %> — <%= v.brand %> <%= v.model %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="form__group">
              <label class="form__label">Conductor</label>
              <input type="text" name="driver_name" class="input" required placeholder="Nombre completo" />
            </div>
            <div class="insp-date">
              <span class="form__label">Fecha y Hora</span>
              <span class="insp-date__value" id="liveDate"></span>
            </div>
          </div>
        </div>

        <!-- ── Two-column body ───────────────────────────────────── -->
        <div class="insp-body">

          <!-- LEFT: Carousel ──────────────────────────────────── -->
          <div class="insp-left">

            <!-- Dot indicators -->
            <div class="car-dots" id="carDots">
              <button type="button" class="car-dot car-dot--active" onclick="goToSlide(0)"></button>
              <button type="button" class="car-dot" onclick="goToSlide(1)"></button>
              <button type="button" class="car-dot" onclick="goToSlide(2)"></button>
              <button type="button" class="car-dot" onclick="goToSlide(3)"></button>
            </div>

            <!-- Carousel track -->
            <div class="car-wrap">
              <div class="car-track" id="carTrack">

                <!-- ── Slide 1: Motor ───────────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#041627 0%,#1a3a5c 100%)">
                    <span class="car-slide__hero-icon">⚙</span>
                    <div>
                      <div class="car-slide__hero-label">Categoría 1 / 4</div>
                      <div class="car-slide__hero-title">Motor y Mecánica</div>
                    </div>
                  </div>
                  <div class="car-slide__body">
                    <% [
                      'Nivel de Aceite (Varilla/Sensor)',
                      'Líquido Refrigerante / Anticongelante',
                      'Estado de Correas y Tensores'
                    ].forEach((item, i) => { %>
                      <label class="chk-row">
                        <input type="checkbox" name="engine_items[]" value="<%= item %>" class="chk-box" />
                        <span class="chk-label"><%= item %></span>
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-group" data-field="engine_rating">
                      <span class="star-group__label">Calificación general</span>
                      <div class="stars" id="starsEngine">
                        <% for(let s=1;s<=5;s++) { %><span class="star" data-val="<%= s %>" onclick="rateStar('engine_rating',<%= s %>)">★</span><% } %>
                      </div>
                      <input type="hidden" name="engine_rating" id="engine_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()" disabled>←</button>
                      <button type="button" class="car-btn car-btn--next" id="nextBtn0" onclick="nextSlide()" disabled>Siguiente →</button>
                    </div>
                  </div>
                </div>

                <!-- ── Slide 2: Luces ───────────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#1a2b3c 0%,#2a4060 100%)">
                    <span class="car-slide__hero-icon">💡</span>
                    <div>
                      <div class="car-slide__hero-label">Categoría 2 / 4</div>
                      <div class="car-slide__hero-title">Sistema de Iluminación</div>
                    </div>
                  </div>
                  <div class="car-slide__body car-slide__body--grid">
                    <% [
                      'Luces de Cruce / Carretera',
                      'Intermitentes / Emergencia',
                      'Luces de Freno / Posición',
                      'Iluminación de Matrícula'
                    ].forEach(item => { %>
                      <label class="chk-row">
                        <input type="checkbox" name="lights_items[]" value="<%= item %>" class="chk-box" />
                        <span class="chk-label"><%= item %></span>
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-group" data-field="lights_rating">
                      <span class="star-group__label">Calificación general</span>
                      <div class="stars" id="starsLights">
                        <% for(let s=1;s<=5;s++) { %><span class="star" data-val="<%= s %>" onclick="rateStar('lights_rating',<%= s %>)">★</span><% } %>
                      </div>
                      <input type="hidden" name="lights_rating" id="lights_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()">←</button>
                      <button type="button" class="car-btn car-btn--next" id="nextBtn1" onclick="nextSlide()" disabled>Siguiente →</button>
                    </div>
                  </div>
                </div>

                <!-- ── Slide 3: Neumáticos ──────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#0d2438 0%,#1a3a5c 100%)">
                    <span class="car-slide__hero-icon">🔵</span>
                    <div>
                      <div class="car-slide__hero-label">Categoría 3 / 4</div>
                      <div class="car-slide__hero-title">Ruedas y Neumáticos</div>
                    </div>
                  </div>
                  <div class="car-slide__body">
                    <% [
                      'Presión de Aire (Visual/Medida)',
                      'Profundidad del Dibujo (Mín 1.6mm)',
                      'Desgaste Irregular / Daños Visibles',
                      'Tuercas y Espárragos de Rueda'
                    ].forEach(item => { %>
                      <label class="chk-row">
                        <input type="checkbox" name="tires_items[]" value="<%= item %>" class="chk-box" />
                        <span class="chk-label"><%= item %></span>
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-group">
                      <span class="star-group__label">Calificación general</span>
                      <div class="stars" id="starsTires">
                        <% for(let s=1;s<=5;s++) { %><span class="star" data-val="<%= s %>" onclick="rateStar('tires_rating',<%= s %>)">★</span><% } %>
                      </div>
                      <input type="hidden" name="tires_rating" id="tires_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()">←</button>
                      <button type="button" class="car-btn car-btn--next" id="nextBtn2" onclick="nextSlide()" disabled>Siguiente →</button>
                    </div>
                  </div>
                </div>

                <!-- ── Slide 4: Seguridad ───────────────────────── -->
                <div class="car-slide">
                  <div class="car-slide__hero" style="background:linear-gradient(135deg,#041627 0%,#fd8b00 160%)">
                    <span class="car-slide__hero-icon">🛡</span>
                    <div>
                      <div class="car-slide__hero-label">Categoría 4 / 4</div>
                      <div class="car-slide__hero-title">Elementos de Seguridad</div>
                    </div>
                  </div>
                  <div class="car-slide__body">
                    <% [
                      'Frenos de Servicio y Estacionamiento',
                      'Extintor (Carga y Fecha Vigente)',
                      'Chalecos y Triángulos de Señalización',
                      'Cinturones de Seguridad'
                    ].forEach(item => { %>
                      <label class="chk-row">
                        <input type="checkbox" name="safety_items[]" value="<%= item %>" class="chk-box" />
                        <span class="chk-label"><%= item %></span>
                      </label>
                    <% }) %>
                  </div>
                  <div class="car-slide__footer">
                    <div class="star-group">
                      <span class="star-group__label">Calificación general</span>
                      <div class="stars" id="starsSafety">
                        <% for(let s=1;s<=5;s++) { %><span class="star" data-val="<%= s %>" onclick="rateStar('safety_rating',<%= s %>)">★</span><% } %>
                      </div>
                      <input type="hidden" name="safety_rating" id="safety_rating" value="" />
                    </div>
                    <div class="car-nav">
                      <button type="button" class="car-btn car-btn--prev" onclick="prevSlide()">←</button>
                      <span class="car-complete-hint">Completa el lado derecho y envía</span>
                    </div>
                  </div>
                </div>

              </div><!-- /car-track -->
            </div><!-- /car-wrap -->
          </div><!-- /insp-left -->

          <!-- RIGHT: Damage map + observations + photos + signature ─ -->
          <div class="insp-right">

            <!-- Vehicle damage map -->
            <section class="insp-panel">
              <h3 class="insp-panel__title">Mapa de Daños</h3>
              <p class="insp-panel__sub">Haz clic sobre la imagen para marcar las áreas afectadas</p>
              <div class="damage-wrap" id="damageWrap">
                <img id="vehicleImg" src="" alt="Selecciona un vehículo" class="damage-img" />
                <canvas id="damageCanvas" class="damage-canvas"></canvas>
                <div class="damage-placeholder" id="damagePlaceholder">
                  <span>Selecciona un vehículo para activar el mapa</span>
                </div>
              </div>
              <div class="damage-actions">
                <button type="button" class="btn btn--ghost btn--sm" onclick="clearDamage()">Limpiar marcas</button>
                <span class="damage-hint" id="damageCount">0 marcas</span>
              </div>
              <input type="hidden" name="damage_map" id="damageMapData" />
            </section>

            <!-- Notes / Observations -->
            <section class="insp-panel">
              <h3 class="insp-panel__title">Observaciones y Notas</h3>
              <textarea name="notes" class="input input--textarea" rows="4"
                placeholder="Describa cualquier anomalía detectada..."></textarea>
            </section>

            <!-- Photo evidence -->
            <section class="insp-panel">
              <h3 class="insp-panel__title">Evidencia Fotográfica</h3>
              <label class="photo-drop" for="photoInput">
                <span class="photo-drop__icon">📷</span>
                <span class="photo-drop__text">Tocar para subir fotos de desperfectos</span>
                <span class="photo-drop__hint">Máx. 5 imágenes · JPG, PNG, WEBP · 5 MB c/u</span>
              </label>
              <input type="file" id="photoInput" name="evidencia" multiple accept="image/*"
                class="photo-file-input" onchange="previewPhotos(this)" />
              <div class="photo-preview-grid" id="photoPreviewGrid"></div>
            </section>

            <!-- Digital signature -->
            <section class="insp-panel">
              <h3 class="insp-panel__title">Firma Digital del Conductor</h3>
              <div class="sig-wrap">
                <canvas id="signatureCanvas" width="380" height="130" class="signature-canvas"></canvas>
                <span class="sig-guide">Firme aquí</span>
              </div>
              <div class="sig-actions">
                <button type="button" class="btn btn--ghost btn--sm" onclick="clearSignature()">Limpiar firma</button>
              </div>
              <input type="hidden" name="signature" id="signatureData" />
            </section>

            <!-- Submit -->
            <button type="submit" class="btn-submit-insp">
              <span>FINALIZAR INSPECCIÓN</span>
            </button>

          </div><!-- /insp-right -->
        </div><!-- /insp-body -->
      </form>

    </div>
  </main>

  <script>
  // ── Live date ─────────────────────────────────────────────────
  (function tick() {
    const el = document.getElementById('liveDate');
    if (el) el.textContent = new Date().toLocaleString('es-ES', {
      weekday:'short', day:'2-digit', month:'short', year:'numeric',
      hour:'2-digit', minute:'2-digit'
    });
    setTimeout(tick, 30000);
  })();

  // ── Carousel ──────────────────────────────────────────────────
  let cur = 0;
  const TOTAL = 4;
  const track = document.getElementById('carTrack');
  const dots  = document.querySelectorAll('.car-dot');

  function goToSlide(n) {
    cur = Math.max(0, Math.min(TOTAL - 1, n));
    track.style.transform = `translateX(-${cur * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('car-dot--active', i === cur));
    // Disable prev on first, handle "next" state
    document.querySelectorAll('.car-btn--prev').forEach(b => b.disabled = cur === 0);
  }

  function nextSlide() { goToSlide(cur + 1); }
  function prevSlide() { goToSlide(cur - 1); }

  // ── Star rating ───────────────────────────────────────────────
  const ratings = { engine_rating: 0, lights_rating: 0, tires_rating: 0, safety_rating: 0 };
  const nextBtns = ['nextBtn0','nextBtn1','nextBtn2'];
  const starContainers = {
    engine_rating: document.getElementById('starsEngine'),
    lights_rating: document.getElementById('starsLights'),
    tires_rating:  document.getElementById('starsTires'),
    safety_rating: document.getElementById('starsSafety'),
  };

  function rateStar(field, val) {
    ratings[field] = val;
    document.getElementById(field).value = val;
    renderStars(field, val);
    // Enable next button for the current slide
    const nextBtnId = 'nextBtn' + cur;
    const btn = document.getElementById(nextBtnId);
    if (btn) btn.disabled = false;
    // Auto-advance after 600ms if not last slide
    if (cur < TOTAL - 1) setTimeout(() => goToSlide(cur + 1), 600);
  }

  function renderStars(field, val) {
    const container = starContainers[field];
    if (!container) return;
    container.querySelectorAll('.star').forEach(s => {
      const v = parseInt(s.dataset.val);
      s.classList.toggle('star--on', v <= val);
    });
  }

  // Star hover effects
  document.querySelectorAll('.stars').forEach(group => {
    group.querySelectorAll('.star').forEach(star => {
      star.addEventListener('mouseenter', () => {
        const v = parseInt(star.dataset.val);
        group.querySelectorAll('.star').forEach(s =>
          s.classList.toggle('star--hover', parseInt(s.dataset.val) <= v));
      });
      star.addEventListener('mouseleave', () => {
        group.querySelectorAll('.star').forEach(s => s.classList.remove('star--hover'));
      });
    });
  });

  // ── Vehicle image + damage map ────────────────────────────────
  const IMAGE_MAP = {
    'camión':      '/images/Trailer.png',
    'furgoneta':   '/images/camioneta.png',
    'automóvil':   '/images/Carro.png',
    'motocicleta': '/images/Moto.png',
  };

  const damageCanvas   = document.getElementById('damageCanvas');
  const damageCtx      = damageCanvas.getContext('2d');
  const vehicleImg     = document.getElementById('vehicleImg');
  const placeholder    = document.getElementById('damagePlaceholder');
  const damageWrap     = document.getElementById('damageWrap');
  const damageCountEl  = document.getElementById('damageCount');
  const marks          = [];
  let   canvasReady    = false;

  function onVehicleChange(sel) {
    const opt  = sel.options[sel.selectedIndex];
    const type = opt ? opt.dataset.type : '';
    const src  = IMAGE_MAP[type] || '';
    if (!src) { placeholder.style.display='flex'; return; }
    placeholder.style.display = 'none';
    vehicleImg.src = src;
    vehicleImg.onload = function() {
      // Fit canvas to the rendered image size
      const rect = vehicleImg.getBoundingClientRect();
      damageCanvas.width  = damageWrap.clientWidth;
      damageCanvas.height = damageWrap.clientHeight;
      canvasReady = true;
      marks.length = 0;
      damageCtx.clearRect(0, 0, damageCanvas.width, damageCanvas.height);
      updateDamageCount();
    };
  }

  damageCanvas.addEventListener('click', function(e) {
    if (!canvasReady) return;
    const rect = damageCanvas.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    marks.push({x, y});
    redrawMarks();
    saveDamageMap();
  });

  // Touch support for damage canvas
  damageCanvas.addEventListener('touchend', function(e) {
    if (!canvasReady) return;
    e.preventDefault();
    const t = e.changedTouches[0];
    const rect = damageCanvas.getBoundingClientRect();
    marks.push({ x: t.clientX - rect.left, y: t.clientY - rect.top });
    redrawMarks();
    saveDamageMap();
  });

  function redrawMarks() {
    damageCtx.clearRect(0, 0, damageCanvas.width, damageCanvas.height);
    marks.forEach(({x, y}, idx) => {
      // Circle
      damageCtx.beginPath();
      damageCtx.arc(x, y, 18, 0, Math.PI * 2);
      damageCtx.strokeStyle = '#ba1a1a';
      damageCtx.lineWidth   = 2.5;
      damageCtx.stroke();
      // Number label
      damageCtx.fillStyle   = '#ba1a1a';
      damageCtx.font        = 'bold 11px Inter, sans-serif';
      damageCtx.textAlign   = 'center';
      damageCtx.textBaseline = 'middle';
      damageCtx.fillText(idx + 1, x, y);
    });
    updateDamageCount();
  }

  function updateDamageCount() {
    damageCountEl.textContent = marks.length + (marks.length === 1 ? ' marca' : ' marcas');
  }

  function saveDamageMap() {
    document.getElementById('damageMapData').value = damageCanvas.toDataURL();
  }

  function clearDamage() {
    marks.length = 0;
    damageCtx.clearRect(0, 0, damageCanvas.width, damageCanvas.height);
    document.getElementById('damageMapData').value = '';
    updateDamageCount();
  }

  // ── Signature ─────────────────────────────────────────────────
  const sigCanvas = document.getElementById('signatureCanvas');
  const sigCtx    = sigCanvas.getContext('2d');
  let drawing     = false;

  function sigPos(e) {
    const r = sigCanvas.getBoundingClientRect();
    return { x:(e.clientX||e.pageX)-r.left, y:(e.clientY||e.pageY)-r.top };
  }
  sigCanvas.addEventListener('mousedown',  e => { drawing=true; sigCtx.beginPath(); sigCtx.moveTo(sigPos(e).x, sigPos(e).y); });
  sigCanvas.addEventListener('mousemove',  e => { if(!drawing)return; const p=sigPos(e); sigCtx.lineTo(p.x,p.y); sigCtx.strokeStyle='#041627'; sigCtx.lineWidth=2; sigCtx.lineCap='round'; sigCtx.stroke(); });
  sigCanvas.addEventListener('mouseup',    () => { drawing=false; saveSignature(); });
  sigCanvas.addEventListener('mouseleave', () => { drawing=false; });
  sigCanvas.addEventListener('touchstart', e => { e.preventDefault(); drawing=true; const t=e.touches[0]; const p=sigPos(t); sigCtx.beginPath(); sigCtx.moveTo(p.x,p.y); });
  sigCanvas.addEventListener('touchmove',  e => { e.preventDefault(); if(!drawing)return; const t=e.touches[0]; const p=sigPos(t); sigCtx.lineTo(p.x,p.y); sigCtx.strokeStyle='#041627'; sigCtx.lineWidth=2; sigCtx.lineCap='round'; sigCtx.stroke(); });
  sigCanvas.addEventListener('touchend',   () => { drawing=false; saveSignature(); });

  function saveSignature() { document.getElementById('signatureData').value = sigCanvas.toDataURL(); }
  function clearSignature() { sigCtx.clearRect(0,0,sigCanvas.width,sigCanvas.height); document.getElementById('signatureData').value=''; }

  // ── Photo preview ─────────────────────────────────────────────
  function previewPhotos(input) {
    const grid = document.getElementById('photoPreviewGrid');
    grid.innerHTML = '';
    const files = Array.from(input.files).slice(0, 5);
    files.forEach(file => {
      const reader = new FileReader();
      reader.onload = e => {
        const div = document.createElement('div');
        div.className = 'photo-thumb';
        div.innerHTML = `<img src="${e.target.result}" alt="preview" />`;
        grid.appendChild(div);
      };
      reader.readAsDataURL(file);
    });
  }
  </script>
</body>
</html>
