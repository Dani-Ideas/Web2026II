<!DOCTYPE html>
<html lang="es">
<head><%- include('../partials/head') %></head>
<body class="layout">
  <%- include('../partials/sidebar', { currentPage: 'inspections' }) %>
  <main class="main">

    <div class="content insp-page">
      <%
        const IMG_MAP = {
          'camión':      '/images/Trailer.png',
          'furgoneta':   '/images/camioneta.png',
          'automóvil':   '/images/Carro.png',
          'motocicleta': '/images/Moto.png',
        };
        const vImgSrc = IMG_MAP[inspection.type] || '';

        const STATUS_LABEL = { pass: 'Aprobado', caution: 'Precaución', fail: 'Fallido' };

        const CATEGORIES = [
          { key: 'engine', label: 'Motor y Mecánica',        icon: '⚙',  gradient: 'linear-gradient(135deg,#041627,#1a3a5c)' },
          { key: 'lights', label: 'Sistema de Iluminación',  icon: '💡', gradient: 'linear-gradient(135deg,#1a2b3c,#2a4060)' },
          { key: 'tires',  label: 'Ruedas y Neumáticos',     icon: '⬤',  gradient: 'linear-gradient(135deg,#0d2438,#1a3a5c)' },
          { key: 'safety', label: 'Elementos de Seguridad',  icon: '🛡',  gradient: 'linear-gradient(135deg,#041627,#7c3a00)' },
        ];
      %>

      <!-- ── Page header ──────────────────────────────────────── -->
      <div class="insp-ph">
        <div class="insp-ph__left">
          <span class="insp-ph__sup">Reporte de Inspección</span>
          <h1 class="insp-ph__title"><%= inspection.brand %> <%= inspection.model %></h1>
          <p class="insp-ph__vehicle">
            Placa: <span class="insp-ph__vehicle-name"><%= inspection.plate %></span>
            &nbsp;·&nbsp; Conductor: <span class="insp-ph__vehicle-name"><%= inspection.driver_name %></span>
          </p>
        </div>
        <div class="insp-ph__right">
          <span class="badge badge--<%= inspection.result %> badge--lg">
            <%= inspection.result === 'pass' ? '✓ Aprobado' : '✗ Fallido' %>
          </span>
          <span class="insp-ph__date-label" style="margin-top:8px">FECHA</span>
          <span class="insp-ph__date-val">
            <%= new Date(inspection.created_at).toLocaleString('es-ES', {
              day:'2-digit', month:'short', year:'numeric',
              hour:'2-digit', minute:'2-digit'
            }).toUpperCase() %>
          </span>
        </div>
      </div>

      <!-- ── Main grid ────────────────────────────────────────── -->
      <div class="insp-grid">

        <!-- LEFT — Category ratings ──────────────────────────── -->
        <div class="insp-left">
          <% CATEGORIES.forEach((cat, idx) => {
               const rating = inspection[cat.key + '_rating'] || 0;
               const status = inspection[cat.key];
          %>
          <div class="show-cat-card">
            <div class="show-cat-card__hero" style="background:<%= cat.gradient %>">
              <span class="car-slide__icon"><%= cat.icon %></span>
              <div>
                <div class="car-slide__cat">Categoría <%= idx+1 %> / 4</div>
                <div class="car-slide__name"><%= cat.label %></div>
              </div>
              <span class="badge badge--<%= status %> show-cat-card__badge">
                <%= STATUS_LABEL[status] || status %>
              </span>
            </div>
            <div class="show-cat-card__body">
              <span class="star-row__label">Calificación</span>
              <div class="stars show-stars">
                <% for (let s = 1; s <= 5; s++) { %>
                  <span class="star <%= s <= rating ? 'star--on' : '' %>" style="cursor:default">&#9733;</span>
                <% } %>
                <span class="show-rating-num"><%= rating %> / 5</span>
              </div>
            </div>
          </div>
          <% }) %>
        </div>

        <!-- RIGHT — Evidence panels ──────────────────────────── -->
        <div class="insp-right">

          <!-- Damage map -->
          <section class="insp-card">
            <h3 class="insp-card__title">Mapa de Daños</h3>
            <% if (vImgSrc) { %>
              <div class="dmg-wrap">
                <img class="dmg-img" src="<%= vImgSrc %>" alt="<%= inspection.type %>" />
                <% if (inspection.damage_map) { %>
                  <img class="dmg-overlay" src="<%= inspection.damage_map %>" alt="marcas de daño" />
                <% } else { %>
                  <div class="dmg-placeholder" style="background:transparent">Sin marcas registradas</div>
                <% } %>
              </div>
            <% } else { %>
              <p class="insp-card__sub">Imagen de vehículo no disponible</p>
            <% } %>
          </section>

          <!-- Notes -->
          <% if (inspection.notes) { %>
          <section class="insp-card">
            <h3 class="insp-card__title">Observaciones</h3>
            <p class="show-notes"><%= inspection.notes %></p>
          </section>
          <% } %>

          <!-- Photos -->
          <% if (inspection.photos) { %>
          <section class="insp-card">
            <h3 class="insp-card__title">Evidencia Fotográfica</h3>
            <div class="photo-preview-grid">
              <% inspection.photos.split(',').forEach(photo => { %>
                <div class="photo-thumb">
                  <img src="/uploads/<%= photo %>" alt="Evidencia" />
                </div>
              <% }) %>
            </div>
          </section>
          <% } %>

          <!-- Signature -->
          <% if (inspection.signature) { %>
          <section class="insp-card">
            <h3 class="insp-card__title">Firma Digital del Conductor</h3>
            <div class="show-sig">
              <img src="<%= inspection.signature %>" alt="Firma" class="show-sig__img" />
              <div class="show-sig__baseline"></div>
            </div>
            <span class="sig-name"><%= inspection.driver_name %></span>
          </section>
          <% } %>

        </div><!-- /insp-right -->
      </div><!-- /insp-grid -->

      <div class="form__actions">
        <a href="/inspecciones" class="btn btn--ghost">&#8592; Volver al historial</a>
      </div>

    </div><!-- /content -->
  </main>
</body>
</html>
